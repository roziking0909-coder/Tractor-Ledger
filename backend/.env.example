# Tractor Ledger - Environment Configuration
# Copy this file to .env and fill in your Supabase credentials

# Supabase Project Settings (find these in Supabase Dashboard -> Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# App Settings
APP_NAME=Tractor Ledger API
APP_VERSION=1.0.0
DEBUG=true

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]

# Admin key for /admin/generate-code (change in production!)
ADMIN_SECRET_KEY=your_secret_key_here_change_this
